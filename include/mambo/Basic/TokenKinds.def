#ifndef TOK
#define TOK(ID)
#endif

#ifndef PUNCTUATOR
#define PUNCTUATOR(ID, VAL) TOK(ID)
#endif

#ifndef KEYWORD
#define KEYWORD(ID, FLAG) TOK(kw_ ## ID)
#endif

TOK(eof)
TOK(unknown)

TOK(symbol)
TOK(number_literal)
TOK(string_literal)

PUNCTUATOR(l_paren, "(")
PUNCTUATOR(r_paren, ")")

KEYWORD(defun,  ALL)
KEYWORD(defvar, ALL)
KEYWORD(let,    ALL)

#undef KEYWORD
#undef PUNCTUATOR
#undef TOK
