#ifndef TOK
#define TOK(ID)
#endif

#ifndef PUNCTUATOR
#define PUNCTUATOR(ID, VAL) TOK(ID)
#endif

#ifndef SPECIALOP
#define SPECIALOP(ID, FLAG) TOK(so_ ## ID)
#endif

TOK(eof)
TOK(unknown)

TOK(symbol)
TOK(number_literal)
TOK(string_literal)

PUNCTUATOR(l_paren, "(")
PUNCTUATOR(r_paren, ")")

SPECIALOP(defun,  ALL)
SPECIALOP(defvar, ALL)
SPECIALOP(let,    ALL)
SPECIALOP(if,    ALL)

#undef SPECIALOP
#undef PUNCTUATOR
#undef TOK
